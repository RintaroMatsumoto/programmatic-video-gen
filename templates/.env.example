# Copy to .env (same directory as package.json) and fill in.
# .env is .gitignored; .env.example is the commitable template.

# Required: Anthropic API key for script generation and EN translation.
ANTHROPIC_API_KEY=

# Optional: override the Claude model used by generate_script.py and
# translate_subtitles.py. Defaults to claude-sonnet-4-6.
# CLAUDE_MODEL=claude-sonnet-4-6

# Optional: override the VOICEVOX engine endpoint.
# VOICEVOX_ENGINE=http://127.0.0.1:50021
